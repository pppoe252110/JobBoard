@page "/forgot-password"

@using JobBoard.Web.Services

@inject AuthApiClient AuthApi
@inject NavigationManager Navigation

@rendermode InteractiveServer

<PageTitle>Forgot Password</PageTitle>

<h1>Forgot Password</h1>

<p>Enter your email address and we'll send you a link to reset your password.</p>

<div class="mb-3">
    <label for="email" class="form-label">Email</label>
    <input type="email" class="form-control" id="email" @bind="email" />
</div>

<button class="btn btn-primary" @onclick="SendResetLink" disabled="@isLoading">
    @(isLoading ? "Sending..." : "Send Reset Link")
</button>

<div class="mt-3">
    <a href="/login">Back to Login</a>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">@message</div>
}

@code {
    private string email = "";
    private bool isLoading = false;
    private string? message;
    private bool isError;

    private async Task SendResetLink()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            message = "Please enter your email.";
            isError = true;
            return;
        }

        isLoading = true;
        message = null;

        var response = await AuthApi.ForgotPasswordAsync(email);
        if (response.IsSuccessStatusCode)
        {
            message = "If the email is registered, a reset link has been sent.";
            isError = false;
        }
        else
        {
            message = "An error occurred. Please try again later.";
            isError = true;
        }

        isLoading = false;
    }
}