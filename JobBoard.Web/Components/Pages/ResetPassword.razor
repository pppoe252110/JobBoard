@page "/reset-password"

@using JobBoard.Web.Services

@inject AuthApiClient AuthApi
@inject NavigationManager Navigation

@rendermode InteractiveServer

<PageTitle>Reset Password</PageTitle>

<h1>Reset Password</h1>

@if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(email))
{
    <div class="alert alert-danger">Invalid reset link.</div>
}
else
{
    <div class="mb-3">
        <label for="newPassword" class="form-label">New Password</label>
        <input type="password" class="form-control" id="newPassword" @bind="newPassword" />
    </div>
    <div class="mb-3">
        <label for="confirmPassword" class="form-label">Confirm New Password</label>
        <input type="password" class="form-control" id="confirmPassword" @bind="confirmPassword" />
    </div>
    <button class="btn btn-primary" @onclick="ResetPasswordAsync" disabled="@isLoading">
        @(isLoading ? "Resetting..." : "Reset Password")
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">@message</div>
    }
}

@code {
    [SupplyParameterFromQuery]
    public string? token { get; set; }

    [SupplyParameterFromQuery]
    public string? email { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private bool isLoading = false;
    private string? message;
    private bool isError;

    private async Task ResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            message = "Please fill in both password fields.";
            isError = true;
            return;
        }

        if (newPassword != confirmPassword)
        {
            message = "Passwords do not match.";
            isError = true;
            return;
        }

        isLoading = true;
        message = null;

        var response = await AuthApi.ResetPasswordAsync(email!, token!, newPassword);
        if (response.IsSuccessStatusCode)
        {
            message = "Password reset successfully! Redirecting to login...";
            isError = false;
            await Task.Delay(2000);
            Navigation.NavigateTo("/login");
        }
        else
        {
            message = "Invalid or expired reset link.";
            isError = true;
        }

        isLoading = false;
    }
}