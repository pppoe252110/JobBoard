@page "/vacancy/{VacancyId:guid}/manage"
@using JobBoard.Web.Services
@inject VacancyApiClient VacancyApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Manage Applications</PageTitle>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold">
            <i class="bi bi-people-fill me-2"></i>Manage Applications
        </h1>
        <a href="/profile" class="btn btn-outline-secondary rounded-pill px-2 px-md-4 text-nowrap">
            <i class="bi bi-arrow-left me-1"></i>Back to Profile
        </a>
    </div>

    @if (applications == null)
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!applications.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 bg-light text-center py-5">
            <div class="card-body">
                <i class="bi bi-inbox fs-1 text-secondary"></i>
                <h5 class="mt-3 fw-semibold">No applications yet</h5>
                <p class="text-secondary">When candidates apply, they'll appear here.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Candidate</th>
                            <th>Resume Title</th>
                            <th>Applied Date</th>
                            <th>Status</th>
                            <th class="pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in applications)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@app.ApplicantName</td>
                                <td>@app.ResumeTitle</td>
                                <td>@app.AppliedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    <select id="status_@app.Id"
                                            name="status_@app.Id"
                                            class="form-select form-select-sm rounded-3 w-auto"
                                            value="@app.Status"
                                            @onchange="@(e => UpdateStatus(app.Id, e.Value?.ToString() ?? "Applied"))">
                                        <option value="Applied">Applied</option>
                                        <option value="Review">Review</option>
                                        <option value="Interview">Interview</option>
                                        <option value="Offered">Offered</option>
                                        <option value="Rejected">Rejected</option>
                                    </select>
                                </td>
                                <td class="pe-4">
                                    <a href="/resume/@app.ResumeId" target="_blank"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-2 px-md-3 text-nowrap">
                                        <i class="bi bi-eye me-1"></i> View Resume
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid VacancyId { get; set; }
    
    private List<ApplicationDto>? applications;

    protected override async Task OnInitializedAsync()
    {
        applications = await VacancyApi.GetApplicationsAsync(VacancyId);
    }

    private async Task UpdateStatus(Guid applicationId, string newStatus)
    {
        var response = await VacancyApi.UpdateApplicationStatusAsync(applicationId, newStatus);
        
        if (response.IsSuccessStatusCode)
        {
            var app = applications?.FirstOrDefault(a => a.Id == applicationId);
            if (app != null)
            {
                var index = applications!.IndexOf(app);
                applications[index] = app with { Status = newStatus };
            }
        }
    }
}