@page "/login"
@inject NavigationManager Navigation

@rendermode InteractiveServer

<PageTitle>Login - JobBoard</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="display-5 text-primary mb-2">
                            <i class="bi bi-box-arrow-in-right"></i>
                        </div>
                        <h2 class="fw-bold">Welcome Back</h2>
                        <p class="text-muted small">Please enter your credentials to log in</p>
                    </div>

                    <form action="/auth/login-callback" method="post">
                        <AntiforgeryToken />

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold text-secondary">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-body border-end-0 rounded-pill rounded-end-0 ps-3">
                                    <i class="bi bi-envelope text-secondary"></i>
                                </span>
                                <input type="email" class="form-control rounded-pill rounded-start-0 ps-2" id="email" name="email" placeholder="name@example.com" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold text-secondary">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-body border-end-0 rounded-pill rounded-end-0 ps-3">
                                    <i class="bi bi-lock text-secondary"></i>
                                </span>
                                <input type="password" class="form-control rounded-pill rounded-start-0 ps-2" id="password" name="password" placeholder="••••••••" required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mb-3">
                            <a href="/forgot-password" class="small text-decoration-none fw-medium">Forgot Password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary rounded-pill w-100 py-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Login
                        </button>
                    </form>

                    @if (ShowError)
                    {
                        <div class="alert alert-danger rounded-3 shadow-sm mt-4 mb-0 d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>Invalid email or password.</div>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <span class="text-muted">Don't have an account?</span>
                        <a href="/register" class="text-primary text-decoration-none fw-semibold ms-1">Register</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool ShowError => Navigation.Uri.Contains("error=true");
}