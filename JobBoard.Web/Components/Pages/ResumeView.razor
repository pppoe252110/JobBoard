@page "/resume/{Id:guid}"
@using JobBoard.Web.Services
@inject ResumeApiClient ResumeApi

<PageTitle>@(resume?.FullName ?? "Resume") - JobBoard</PageTitle>

@if (resume == null)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="container py-5">

        <div class="card shadow-lg rounded-5 overflow-hidden mb-5">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center g-4">
                    <div class="col-md-8">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <h1 class="display-5 fw-bold mb-0">@resume.FullName</h1>
                            <span class="badge rounded-pill text-bg-success px-3">Open to work</span>
                        </div>
                        <h4 class="text-secondary fw-light mb-4">@resume.Title</h4>

                        <div class="d-flex flex-wrap gap-3">
                            <div class="d-flex align-items-center text-body-secondary">
                                <i class="bi bi-geo-alt-fill me-2"></i>@resume.Location
                            </div>
                            <div class="vr d-none d-sm-block"></div>
                            <div class="d-flex align-items-center text-body-secondary">
                                <i class="bi bi-calendar-check me-2"></i>Updated @DateTime.Now.ToString("MMM yyyy")
                            </div>
                        </div>
                    </div>

@*                     <div class="col-md-4 text-md-end">
                        <button class="btn btn-primary btn-lg rounded-pill px-5 shadow">
                            <i class="bi bi-download me-2"></i>Download CV
                        </button>
                    </div> *@
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
            
                <div class="card shadow rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 d-flex align-items-center">
                            <i class="bi bi-person-lines-fill me-2"></i>Contact
                        </h5>

                        <div class="vstack gap-3">
                            @foreach (var contact in resume.ContactMethods ?? [])
                            {
                                <div class="d-flex align-items-center p-2 rounded-3 bg-body-tertiary border border-light-subtle">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-@(GetContactIcon(contact.Type))"></i>
                                    </div>
                                    <div class="text-truncate small fw-medium">@contact.Value</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card shadow rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 d-flex align-items-center">
                            <i class="bi bi-lightning-charge-fill me-2"></i>Expertise
                        </h5>

                        @if (resume.Skills?.Languages?.Any() == true)
                        {
                            <div class="mb-4">
                                <label class="small fw-bold text-uppercase tracking-wider text-body-secondary mb-3 d-block">Communication</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var lang in resume.Skills.Languages)
                                    {
                                        <span class="badge border text-body rounded-pill px-3 py-2 bg-body-tertiary">
                                            @lang.Name <span class="opacity-50 mx-1">|</span> @lang.Level
                                        </span>
                                    }
                                </div>
                            </div>
                        }

                        @if (resume.Skills?.HardSkills?.Any() == true)
                        {
                            <div>
                                <label class="small fw-bold text-uppercase tracking-wider text-body-secondary mb-3 d-block">Technical Stack</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var skill in resume.Skills.HardSkills)
                                    {
                                        <span class="badge rounded-pill text-bg-primary bg-opacity-10 text-body border-1 px-3 py-2">
                                            @skill
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">

                <div class="card shadow rounded-4 mb-4">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="fw-bold mb-4">Professional Summary</h5>
                        <p class="lead-sm text-body-secondary lh-lg mb-0">
                            @resume.AboutMe
                        </p>
                    </div>
                </div>

                <div class="card shadow rounded-4">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="fw-bold mb-5">Work Experience</h5>

                        <div class="position-relative">
                            @if (resume.WorkExperiences?.Any() == true)
                            {
                                <div class="vr position-absolute h-100 d-none d-md-block"></div>
                            }
                            <div class="vstack gap-5 ps-md-4">
                                @foreach (var we in resume.WorkExperiences.OrderByDescending(x => x.StartDate))
                                {
                                    <div class="position-relative">
                                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start mb-3">
                                            <div>
                                                <h5 class="fw-bold mb-1">@we.Position</h5>
                                                <div class="text-primary fw-medium">@we.CompanyName</div>
                                            </div>
                                            <div class="badge bg-body-tertiary text-body border px-3 py-2 rounded-pill mt-2 mt-md-0">
                                                @we.StartDate.ToString("MMM yyyy") — @(we.EndDate?.ToString("MMM yyyy") ?? "Present")
                                            </div>
                                        </div>

                                        <p class="text-body-secondary mb-4">
                                            @we.Description
                                        </p>

                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var tech in we.Technologies ?? [])
                                            {
                                                <span class="badge rounded-2 bg-body-secondary text-body-secondary small fw-normal">
                                                    #@tech
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ResumeResponse? resume;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            resume = await ResumeApi.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching resume: {ex.Message}");
        }
    }

    private string GetContactIcon(string type)
    {
        return type.ToLowerInvariant() switch
        {
            "email" => "envelope",
            "phone" => "telephone",
            "website" => "globe",
            "linkedin" => "linkedin",
            "github" => "github",
            "twitter" => "twitter",
            _ => "link"
        };
    }
}