@page "/resume/{Id:guid}"
@using JobBoard.Web.Services
@inject ResumeApiClient ResumeApi

<PageTitle>@(resume?.FullName ?? "Resume") - JobBoard</PageTitle>

@if (resume == null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="container py-4">
        <div class="card shadow-sm border mb-4">
            <div class="card-body d-flex justify-content-between align-items-start p-4">
                <div>
                    <h1 class="fw-bold mb-1">@resume.FullName</h1>
                    <h2 class="h4 text-muted mb-3">@resume.Title</h2>
                    <span class="badge bg-success">Open to work</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-primary"><i class="bi bi-download me-2"></i>PDF</button>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Contact Information</h5>
                        <ul class="list-unstyled text-muted">
                            <li class="mb-2"><i class="bi bi-geo-alt me-2"></i> @resume.Location</li>
                            @if (resume.ContactMethods != null)
                            {
                                @foreach (var contact in resume.ContactMethods)
                                {
                                    <li class="mb-2">
                                        <i class="bi bi-@(GetContactIcon(contact.Type)) me-2"></i>
                                        @contact.Value
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border mb-4">
                    <div class="card-body p-4">
                        <p class="text-muted">@resume.AboutMe</p>
                    </div>
                </div>

                <div class="card shadow-sm border mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Skills</h5>
                        <h6 class="text-muted mb-2 mt-3">Languages</h6>
                        <div>
                            @foreach (var lang in resume.Skills.Languages)
                            {
                                <span class="badge rounded-pill border px-3 py-2 me-1 mb-1 shadow-sm">
                                    <i class="bi bi-translate me-1 opacity-75"></i>
                                    @lang.Name
                                    <span class="ms-1 opacity-50 fw-normal">| @lang.Level</span>
                                </span>
                            }
                        </div>
                        <h6 class="text-muted mb-2 mt-3">Frameworks & Tools</h6>
                        <div>
                            @foreach (var fw in resume.Skills.HardSkills)
                            {
                                <span class="badge bg-secondary me-1 mb-1 p-2">@fw</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Experience</h5>
                        <div class="list-group">
                            @foreach (var we in resume.WorkExperiences.OrderByDescending(x => x.StartDate))
                            {
                                <div class="list-group-item">
                                    <h6 class="fw-bold mb-1">@we.Position</h6>
                                    <div class="text-muted small mb-2">
                                        <i class="bi bi-building me-1"></i> @we.CompanyName &bull;
                                        @we.StartDate.ToString("MMM yyyy") - @(we.EndDate?.ToString("MMM yyyy") ?? "Present")
                                    </div>
                                    <p class="text-muted mb-2">@we.Description</p>
                                    <div>
                                        @foreach (var tech in we.Technologies)
                                        {
                                            <span class="badge bg-dark border text-light me-1">@tech</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ResumeResponse? resume;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA");
            resume = await ResumeApi.GetByIdAsync(Id);
            Console.WriteLine("BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching resume: {ex.Message}");
        }
    }

    private string GetContactIcon(string type)
    {
        return type.ToLowerInvariant() switch
        {
            "email" => "envelope",
            "phone" => "telephone",
            "website" => "globe",
            "linkedin" => "linkedin",
            "github" => "github",
            "twitter" => "twitter",
            _ => "link"
        };
    }
}