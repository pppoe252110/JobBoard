@page "/vacancy/{Id:guid}"
@using JobBoard.Web.Services
@using JobBoard.Web.Models
@using Markdig
@using Microsoft.AspNetCore.Components.Authorization
@inject VacancyApiClient VacancyApi
@inject ResumeApiClient ResumeApi
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(vacancy?.Title ?? "Vacancy") - JobBoard</PageTitle>

@if (vacancy == null)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="container py-5">

        <div class="card shadow-lg rounded-5 overflow-hidden mb-5">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center g-4">
                    <div class="col-md-8">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <h1 class="display-5 fw-bold mb-0">@vacancy.Title</h1>
                            @if (vacancy.IsRemote)
                            {
                                <span class="badge rounded-pill text-bg-info px-3">Remote</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill text-bg-secondary px-3">On‑site</span>
                            }
                        </div>

                        @if (vacancy.SalaryFrom.HasValue || vacancy.SalaryTo.HasValue)
                        {
                            <h4 class="text-primary-emphasis fw-light mb-4">
                                @if (vacancy.SalaryFrom.HasValue && vacancy.SalaryTo.HasValue)
                                {
                                    @($"${vacancy.SalaryFrom:N0} – ${vacancy.SalaryTo:N0}")
                                }
                                else if (vacancy.SalaryFrom.HasValue)
                                {
                                    @($"From ${vacancy.SalaryFrom:N0}")
                                }
                                else if (vacancy.SalaryTo.HasValue)
                                {
                                    @($"Up to ${vacancy.SalaryTo:N0}")
                                }
                            </h4>
                        }

                        <div class="d-flex flex-wrap gap-3">
                            <div class="d-flex align-items-center text-body-secondary">
                                <i class="bi bi-geo-alt-fill me-2"></i>@(string.IsNullOrWhiteSpace(vacancy.Location) ? "Not specified" : vacancy.Location)
                            </div>
                            <div class="vr d-none d-sm-block"></div>
                            <div class="d-flex align-items-center text-body-secondary">
                                <i class="bi bi-wifi me-2"></i>@(vacancy.IsRemote ? "Remote" : "On‑site / Hybrid")
                            </div>
                            <div class="vr d-none d-sm-block"></div>
                            <div class="d-flex align-items-center text-body-secondary">
                                <i class="bi bi-calendar-check me-2"></i>Posted @vacancy.CreatedAt.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                    </div>

                    @* Ensure user cannot interact with their own vacancy *@
                    @if (currentUserId == null || currentUserId != vacancy.UserId)
                    {
                        <div class="col-md-4 text-md-end d-flex flex-column gap-2">
                            <button class="btn btn-primary btn-lg rounded-pill px-5 shadow" @onclick="PromptApply">
                                <i class="bi bi-send-fill me-2"></i>Apply
                            </button>
                            <a href="/chat/@vacancy.UserId" class="btn btn-outline-secondary btn-lg rounded-pill px-5 shadow">
                                <i class="bi bi-chat-dots me-2"></i>Message Employer
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card shadow rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 d-flex align-items-center">
                            <i class="bi bi-info-circle-fill me-2"></i>Details
                        </h5>

                        <div class="vstack gap-3">
                            <div class="d-flex align-items-center p-2 rounded-3 bg-body-tertiary border border-light-subtle">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-geo-alt-fill"></i>
                                </div>
                                <div class="text-truncate small fw-medium">Location: @(string.IsNullOrWhiteSpace(vacancy.Location) ? "Not specified" : vacancy.Location)</div>
                            </div>

                            <div class="d-flex align-items-center p-2 rounded-3 bg-body-tertiary border border-light-subtle">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-briefcase-fill"></i>
                                </div>
                                <div class="text-truncate small fw-medium">Work Type: @(vacancy.IsRemote ? "Remote" : "On‑site / Hybrid")</div>
                            </div>

                            <div class="d-flex align-items-center p-2 rounded-3 bg-body-tertiary border border-light-subtle">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-calendar-fill"></i>
                                </div>
                                <div class="text-truncate small fw-medium">Posted: @vacancy.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </div>

                            @if (vacancy.SalaryFrom.HasValue || vacancy.SalaryTo.HasValue)
                            {
                                <div class="d-flex align-items-center p-2 rounded-3 bg-body-tertiary border border-light-subtle">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                    <div class="text-truncate small fw-medium">
                                        Salary:
                                        @if (vacancy.SalaryFrom.HasValue && vacancy.SalaryTo.HasValue)
                                        {
                                            @($"${vacancy.SalaryFrom:N0} – ${vacancy.SalaryTo:N0}")
                                        }
                                        else if (vacancy.SalaryFrom.HasValue)
                                        {
                                            @($"From ${vacancy.SalaryFrom:N0}")
                                        }
                                        else if (vacancy.SalaryTo.HasValue)
                                        {
                                            @($"Up to ${vacancy.SalaryTo:N0}")
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow rounded-4">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="fw-bold mb-4">Job Description</h5>
                        @if (!string.IsNullOrWhiteSpace(vacancy.DescriptionMarkdown))
                        {
                            <div class="lead-sm lh-lg">
                                @((MarkupString)Markdig.Markdown.ToHtml(vacancy.DescriptionMarkdown, pipeline))
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No description provided.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="modal fade" id="noResumeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create a Resume</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>You need to create a resume before applying for vacancies. Would you like to create one now?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="GoToResumes">Go to Resumes</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="selectResumeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Resume</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Which resume would you like to submit for this application?</p>
                    @if (userResumes != null && userResumes.Any())
                    {
                        <select class="form-select" @bind="selectedResumeIdToApply">
                            @foreach (var resume in userResumes)
                            {
                                <option value="@resume.Id">@resume.Title - @resume.FullName</option>
                            }
                        </select>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmApply">Submit Application</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MarkdownPipeline pipeline;
    private VacancyResponse? vacancy;
    private Guid? currentUserId;
    private List<ResumeResponse>? userResumes;
    private Guid? selectedResumeIdToApply;

    protected override async Task OnInitializedAsync()
    {
        pipeline = new MarkdownPipelineBuilder()
            .DisableHtml()
            .UseAdvancedExtensions()
            .UseEmojiAndSmiley()
            .UseSoftlineBreakAsHardlineBreak()
            .UseBootstrap()
            .Build();
            
        await LoadVacancy();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = authState.User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value;
            if (Guid.TryParse(userIdClaim, out var id)) currentUserId = id;

            userResumes = await ResumeApi.GetUserResumesAsync();
        }
    }

    private async Task LoadVacancy()
    {
        try
        {
            vacancy = await VacancyApi.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading vacancy: {ex.Message}");
        }
    }

    private async Task PromptApply()
    {
        // Not logged in → redirect to login
        if (currentUserId == null || userResumes == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Logged in but no resume → show the modal
        if (!userResumes.Any())
        {
            await JSRuntime.InvokeVoidAsync("showModal", "#noResumeModal");
            return;
        }

        // Has at least one resume → open selection modal
        selectedResumeIdToApply = userResumes.First().Id;
        await JSRuntime.InvokeVoidAsync("showModal", "#selectResumeModal");
    }

    private async Task ConfirmApply()
    {
        if (!selectedResumeIdToApply.HasValue) return;

        var response = await VacancyApi.ApplyAsync(Id, selectedResumeIdToApply.Value);
        await JSRuntime.InvokeVoidAsync("hideModal", "#selectResumeModal");

        if (response.IsSuccessStatusCode)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Application submitted!");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to apply: {error}");
        }
    }

    private async Task GoToResumes()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "#noResumeModal");
        Navigation.NavigateTo("/profile?tab=resumes");
    }

    private async Task Reload()
    {
        await LoadVacancy();
        StateHasChanged();
    }
}