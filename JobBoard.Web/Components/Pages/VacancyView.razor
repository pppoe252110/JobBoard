@page "/vacancy/{Id:guid}"
@using JobBoard.Web.Services
@using Markdig
@inject VacancyApiClient VacancyApi
@inject IJSRuntime JSRuntime

<PageTitle>@(vacancy?.Title ?? "Vacancy") - JobBoard</PageTitle>

@if (vacancy == null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="container py-4">
        <!-- Header Card -->
        <div class="card shadow-sm border mb-4">
            <div class="card-body d-flex justify-content-between align-items-start p-4">
                <div>
                    <h1 class="fw-bold mb-1">@vacancy.Title</h1>
                    @if (vacancy.SalaryFrom.HasValue || vacancy.SalaryTo.HasValue)
                    {
                        <h2 class="h4 text-muted mb-3">
                            Salary:
                            @if (vacancy.SalaryFrom.HasValue && vacancy.SalaryTo.HasValue)
                                @($"${vacancy.SalaryFrom:N0} - ${vacancy.SalaryTo:N0}")
                            else if (vacancy.SalaryFrom.HasValue)
                                @($"From ${vacancy.SalaryFrom:N0}")
                            else if (vacancy.SalaryTo.HasValue)
                                @($"Up to ${vacancy.SalaryTo:N0}")
                        </h2>
                    }
                    <div>
                        @if (vacancy.IsRemote)
                        {
                            <span class="badge bg-info me-2">Remote</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(vacancy.Location))
                        {
                            <span class="badge bg-secondary">@vacancy.Location</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Details</h5>
                        <ul class="list-unstyled text-muted">
                            <li class="mb-2">
                                <i class="bi bi-geo-alt me-2"></i>
                                Location: @(string.IsNullOrWhiteSpace(vacancy.Location) ? "Not specified" : vacancy.Location)
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-wifi me-2"></i>
                                Work Type: @(vacancy.IsRemote ? "Remote" : "On‑site / Hybrid")
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-calendar me-2"></i>
                                Posted: @vacancy.CreatedAt.ToString("MMM dd, yyyy")
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Description</h5>
                        @if (!string.IsNullOrWhiteSpace(vacancy.DescriptionMarkdown))
                        {
                            @((MarkupString)Markdig.Markdown.ToHtml(vacancy.DescriptionMarkdown, pipeline))
                        }
                        else
                        {
                            <p class="text-muted">No description provided.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MarkdownPipeline pipeline;
    private VacancyResponse? vacancy;

    protected override async Task OnInitializedAsync()
    {
        pipeline = new MarkdownPipelineBuilder()
            .UseAdvancedExtensions().UseEmojiAndSmiley().UseSoftlineBreakAsHardlineBreak().UseBootstrap()
            .Build();

        await LoadVacancy();
    }

    private async Task LoadVacancy()
    {
        try
        {
            vacancy = await VacancyApi.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading vacancy: {ex.Message}");
        }
    }

    private async Task Reload()
    {
        await LoadVacancy();
        StateHasChanged();
    }
}