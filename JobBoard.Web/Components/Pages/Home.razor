@page "/"
<PageTitle>Home - JobBoard</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary mb-3">Welcome to JobBoard</h1>
        <p class="lead text-muted">Your next great opportunity or perfect candidate is just a click away.</p>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-md-5">
            <div class="card h-100 border-0 shadow rounded-4 overflow-hidden transition-hover">
                <div class="card-body p-5 text-center">
                    <div class="display-1 text-primary mb-4">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold mb-3">Vacancies</h2>
                    <p class="text-muted mb-4">Browse thousands of job openings and find your dream career.</p>
                    <a href="vacancies" class="btn btn-primary rounded-pill px-4 py-2 stretched-link">Find a Job</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 border-0 shadow rounded-4 overflow-hidden transition-hover">
                <div class="card-body p-5 text-center">
                    <div class="display-1 text-primary mb-4">
                        <i class="bi bi-file-earmark-person-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold mb-3">Resumes (CVs)</h2>
                    <p class="text-muted mb-4">Explore talented professionals and find the perfect fit for your team.</p>
                    <a href="resumes" class="btn btn-outline-primary rounded-pill px-4 py-2 stretched-link">Browse Candidates</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.125) !important;
    }
</style>