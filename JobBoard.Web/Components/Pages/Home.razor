@page "/"

<PageTitle>Home - JobBoard</PageTitle>

<div class="container py-5 text-center">
    <h1 class="display-4 fw-bold text-primary mb-3">Welcome to JobBoard</h1>
    <p class="lead text-muted mb-5">Your next great opportunity or perfect candidate is just a click away.</p>

    <div class="row justify-content-center gap-4">
        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0 position-relative" style="background-color: var(--bg-card); transition: transform 0.2s;">
                <div class="card-body p-5">
                    <div class="display-1 text-primary mb-3">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold">Vacancies</h2>
                    <p class="text-muted mb-4">Browse thousands of job openings and find your dream career.</p>
                    <a href="vacancies" class="btn btn-primary btn-lg w-100 stretched-link">Find a Job</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0 position-relative" style="background-color: var(--bg-card); transition: transform 0.2s;">
                <div class="card-body p-5">
                    <div class="display-1 text-accent mb-3">
                        <i class="bi bi-file-earmark-person-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold">Resumes (CVs)</h2>
                    <p class="text-muted mb-4">Explore talented professionals and find the perfect fit for your team.</p>
                    <a href="resumes" class="btn btn-outline-primary btn-lg w-100 stretched-link">Browse Candidates</a>
                </div>
            </div>
        </div>
    </div>
</div>