@using JobBoard.Web.Services
@using Markdig

@inject VacancyApiClient VacancyApi
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<!-- Vacancy Modal -->
<div class="modal fade" id="vacancyModal" aria-labelledby="vacancyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-header pb-0">
                <h5 class="modal-title fw-bold" id="vacancyModalLabel">
                    <i class="bi bi-briefcase-fill me-2"></i>@(IsEdit ? "Edit Vacancy" : "Create Vacancy")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-0">
                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary" for="VacancyTitle">Title</label>
                    <input type="text" class="form-control rounded-3" id="VacancyTitle" name="VacancyTitle" @bind="model.Title" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary" for="VacancyDescriptionMarkdown">Description (Markdown)</label>
                    <textarea class="form-control rounded-3" id="VacancyDescriptionMarkdown" name="VacancyDescriptionMarkdown" rows="6"
                              @bind="model.DescriptionMarkdown"
                                  @bind:event="oninput">
                    </textarea>
                        <div class="mt-2">
                            <small class="text-muted">Supports Markdown formatting. Preview:</small>
                            <div class="border rounded-3 p-3 mt-1 bg-body-tertiary">
                                @((MarkupString)Markdig.Markdown.ToHtml(model.DescriptionMarkdown ?? "", pipeline))
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary" for="VacancySalaryFrom">Salary From</label>
                            <input type="number" class="form-control rounded-3" id="VacancySalaryFrom" name="VacancySalaryFrom" @bind="model.SalaryFrom" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary" for="VacancySalaryTo">Salary To</label>
                            <input type="number" class="form-control rounded-3" id="VacancySalaryTo" name="VacancySalaryTo" @bind="model.SalaryTo" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold text-secondary" for="VacancyLocation">Location</label>
                            <input type="text" class="form-control rounded-3" id="VacancyLocation" name="VacancyLocation" @bind="model.Location" placeholder="City, Country or Remote" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-3">
                                <input class="form-check-input rounded-3" type="checkbox" id="VacancyIsRemote" name="VacancyIsRemote" @bind="model.IsRemote" />
                                <label class="form-check-label text-secondary" for="VacancyIsRemote">
                                    <i class="bi bi-wifi me-1"></i> Remote position
                                </label>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger rounded-3 mt-3">@ErrorMessage</div>
                    }
                </div>
                <div class="modal-footer pt-0">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="Save" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>

@code {
    [Parameter] public VacancyResponse? ExistingVacancy { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }

    private MarkupString markup;
    private MarkdownPipeline pipeline;
    private VacancyFormModel model = new();
    private bool isSaving;
    private string? ErrorMessage;
    private bool IsEdit => ExistingVacancy != null;

    protected override void OnInitialized()
    {
        pipeline = new MarkdownPipelineBuilder().DisableHtml()
            .UseAdvancedExtensions().UseEmojiAndSmiley().UseSoftlineBreakAsHardlineBreak().UseBootstrap()
            .Build();

        // Initialize model from parameter if present (this runs once, but OnParametersSet will handle updates)
        UpdateModelFromParameter();
        UpdatePreview();
    }

    protected override void OnParametersSet()
    {
        // When parameters change (e.g., modal is opened with a different vacancy), update the model.
        UpdateModelFromParameter();
        UpdatePreview();
        StateHasChanged();
    }

    private void UpdateModelFromParameter()
    {
        if (IsEdit && ExistingVacancy != null)
        {
            model = new VacancyFormModel
            {
                Id = ExistingVacancy.Id,
                Title = ExistingVacancy.Title,
                DescriptionMarkdown = ExistingVacancy.DescriptionMarkdown,
                SalaryFrom = ExistingVacancy.SalaryFrom,
                SalaryTo = ExistingVacancy.SalaryTo,
                Location = ExistingVacancy.Location,
                IsRemote = ExistingVacancy.IsRemote
            };
        }
        else
        {
            // Reset for create mode
            model = new VacancyFormModel
            {
                Id = null,
                Title = "",
                DescriptionMarkdown = "",
                SalaryFrom = null,
                SalaryTo = null,
                Location = "",
                IsRemote = false
            };
        }
    }

    private void UpdatePreview()
    {
        markup = (MarkupString)Markdig.Markdown.ToHtml(model.DescriptionMarkdown, pipeline);
    }

    private async Task Save()
    {
        isSaving = true;
        ErrorMessage = null;

        try
        {
            HttpResponseMessage response;
            if (IsEdit && model.Id.HasValue)
            {
                var request = new UpdateVacancyRequest(
                    model.Id.Value,
                    model.Title,
                    model.DescriptionMarkdown,
                    model.SalaryFrom,
                    model.SalaryTo,
                    model.Location,
                    model.IsRemote
                );
                response = await VacancyApi.UpdateAsync(model.Id.Value, request);
            }
            else
            {
                var request = new CreateVacancyRequest(
                    model.Title,
                    model.DescriptionMarkdown,
                    model.SalaryFrom,
                    model.SalaryTo,
                    model.Location,
                    model.IsRemote
                );
                response = await VacancyApi.CreateAsync(request);
            }

            if (response.IsSuccessStatusCode)
            {
                await OnSuccess.InvokeAsync();
                await CloseModal();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Error: {error}";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CloseModal()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "#vacancyModal");
    }

    public class VacancyFormModel
    {
        public Guid? Id { get; set; }
        public string Title { get; set; } = "";
        public string DescriptionMarkdown { get; set; } = "";
        public decimal? SalaryFrom { get; set; }
        public decimal? SalaryTo { get; set; }
        public string? Location { get; set; } = "";
        public bool IsRemote { get; set; }
    }
}