@using JobBoard.Web.Services
@using JobBoard.Web.Utils
@inject ResumeApiClient ResumeApi
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<div class="modal fade" id="resumeModal" aria-labelledby="resumeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold" id="resumeModalLabel">@(IsEdit ? "Edit Resume" : "Create Resume")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label text-muted">Full Name</label>
                        <input type="text" class="form-control" @bind="model.FullName" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label text-muted">Headline / Title</label>
                        <input type="text" class="form-control" @bind="model.Title" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label text-muted">Location</label>
                        <input type="text" class="form-control" @bind="model.Location" placeholder="City, Country" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted">Expected Salary (USD)</label>
                        <input type="number" class="form-control" @bind="model.ExpectedSalary" step="1000" placeholder="e.g., 80000" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">About Me</label>
                    <textarea class="form-control" rows="4" @bind="model.AboutMe"></textarea>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Contact Methods</h5>
                <div class="mb-3">
                    @for (int i = 0; i < model.ContactMethods.Count; i++)
                    {
                        var contact = model.ContactMethods[i];
                        <div class="row mb-2 align-items-end">
                            <div class="col-md-4">
                                <select class="form-select" @bind="contact.Type">
                                    <option value="">-- Select --</option>
                                    <option value="Email">Email</option>
                                    <option value="Phone">Phone</option>
                                    <option value="LinkedIn">LinkedIn</option>
                                    <option value="GitHub">GitHub</option>
                                    <option value="Website">Website</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Value" @bind="contact.Value" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" @onclick="() => RemoveContact(contact)">Remove</button>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" @onclick="AddContact">
                        <i class="bi bi-plus-circle"></i> Add Contact
                    </button>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Languages</h5>
                <div class="mb-3">
                    @for (int i = 0; i < model.Languages.Count; i++)
                    {
                        var lang = model.Languages[i];
                        <div class="row mb-2 align-items-end">
                            <div class="col-md-5">
                                <select class="form-select" @bind="lang.Name">
                                    <option value="">-- Select Language --</option>
                                    @foreach (var langOption in GetAvailableLanguages(lang.Name))
                                    {
                                        <option value="@langOption">@langOption</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-5">
                                <select class="form-select" @bind="lang.Level">
                                    <option value="">-- Level --</option>
                                    <option value="A1">A1</option>
                                    <option value="A2">A2</option>
                                    <option value="B1">B1</option>
                                    <option value="B2">B2</option>
                                    <option value="C1">C1</option>
                                    <option value="C2">C2</option>
                                    <option value="Native">Native</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" @onclick="() => RemoveLanguage(lang)">Remove</button>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" @onclick="AddLanguage">
                        <i class="bi bi-plus-circle"></i> Add Language
                    </button>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Frameworks & Tools</h5>
                <div class="mb-3">
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               placeholder="Type framework and press Enter"
                               @bind="newFramework"
                               @bind:event="oninput"
                               @onkeypress="OnFrameworkKeyPress" />
                        <button class="btn btn-outline-primary" type="button" @onclick="AddFramework">Add</button>
                    </div>
                    <div class="mt-2 d-flex flex-wrap gap-2">
                        @foreach (var fw in model.Frameworks)
                        {
                            <span class="badge bg-info text-dark p-2 d-flex align-items-center gap-2">
                                @fw
                                <button type="button" class="btn-close ms-1" @onclick="() => RemoveFramework(fw)"></button>
                            </span>
                        }
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="isVisibleCheck" @bind="model.IsVisible" />
                    <label class="form-check-label text-muted" for="isVisibleCheck">Visible to employers</label>
                </div>

                <hr class="my-4" />

                <h5 class="fw-bold mb-3">Work Experience</h5>
                @for (int i = 0; i < model.WorkExperiences.Count; i++)
                {
                    var we = model.WorkExperiences[i];
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label text-muted">Company</label>
                                    <input type="text" class="form-control" @bind="we.CompanyName" />
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label text-muted">Position</label>
                                    <input type="text" class="form-control" @bind="we.Position" />
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label text-muted">Start Date</label>
                                    <input type="month" class="form-control" @bind="we.StartMonthYear" max="@GetCurrentYearMonth()" />
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label text-muted">End Date (leave blank if current)</label>
                                    <input type="month" class="form-control" @bind="we.EndMonthYear" max="@GetCurrentYearMonth()" />
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label text-muted">Technologies Used</label>
                                <div class="input-group mb-2">
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Type tech (e.g. Docker) and press Enter"
                                           @bind="we.NewTech"
                                           @bind:event="oninput"
                                           @onkeydown="(e) => OnTechKeyPress(e, we)" />
                                    <button class="btn btn-outline-primary" type="button" @onclick="() => AddTech(we)">Add</button>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var tech in we.Technologies)
                                    {
                                        <span class="badge bg-secondary p-2 d-flex align-items-center gap-2">
                                            @tech
                                            <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.5rem;" @onclick="() => RemoveTech(we, tech)"></button>
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted">Description</label>
                                <textarea class="form-control" rows="2" @bind="we.Description"></textarea>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveWorkExperience(we)">
                                <i class="bi bi-trash"></i> Remove Role
                            </button>
                        </div>
                    </div>
                }
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddWorkExperience">
                    <i class="bi bi-plus-circle"></i> Add Work Experience
                </button>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@ErrorMessage</div>
                }
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Profile")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public ResumeResponse? ExistingResume { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }

    private ResumeFormModel model = new();
    private bool isSaving;
    private string? ErrorMessage;
    private bool IsEdit => ExistingResume != null;

    private string newFramework = "";

    protected override void OnParametersSet()
    {
        if (IsEdit && ExistingResume != null)
        {
            model = new ResumeFormModel
            {
                Id = ExistingResume.Id,
                FullName = ExistingResume.FullName,
                Title = ExistingResume.Title,
                Location = ExistingResume.Location,
                ExpectedSalary = ExistingResume.ExpectedSalary,
                AboutMe = ExistingResume.AboutMe,
                IsVisible = ExistingResume.IsVisible,
                ContactMethods = ExistingResume.ContactMethods.Select(c => new ContactMethodDto { Type = c.Type, Value = c.Value }).ToList(),
                Languages = ExistingResume.Skills.Languages.Select(l => new LanguageDto { Name = l.Name, Level = l.Level }).ToList(),
                Frameworks = ExistingResume.Skills.HardSkills.ToList(),
                WorkExperiences = ExistingResume.WorkExperiences.Select(we => new WorkExperienceFormModel
                {
                    Id = we.Id,
                    CompanyName = we.CompanyName,
                    Position = we.Position,
                    StartDate = we.StartDate,
                    EndDate = we.EndDate,
                    Description = we.Description,
                    Technologies = we.Technologies.ToList()
                }).ToList()
            };
        }
        else
        {
            model = new();
        }
    }

    private IEnumerable<string> GetAvailableLanguages(string currentLanguage)
    {
        var selectedNames = model.Languages
            .Select(l => l.Name)
            .Where(n => n != currentLanguage) // Don't filter out the one I'm currently using
            .ToHashSet();

        return LanguageData.AllLanguageNames.Where(lang => !selectedNames.Contains(lang));
    }

    private void AddTech(WorkExperienceFormModel we)
    {
        var trimmed = we.NewTech?.Trim();

        if (!string.IsNullOrWhiteSpace(trimmed))
        {
            bool alreadyExists = we.Technologies
                .Any(t => string.Equals(t, trimmed, StringComparison.OrdinalIgnoreCase));

            if (!alreadyExists)
            {
                we.Technologies.Add(trimmed);
            }
        }

        we.NewTech = ""; // Clear input regardless of success/duplicate
    }

    private void OnTechKeyPress(KeyboardEventArgs e, WorkExperienceFormModel we)
    {
        if (e.Key == "Enter")
        {
            AddTech(we);
        }
    }

    private void RemoveTech(WorkExperienceFormModel we, string tech)
    {
        we.Technologies.Remove(tech);
    }

    private string GetCurrentYearMonth() => DateTime.Now.ToString("yyyy-MM");

    // Contact methods
    private void AddContact()
    {
        model.ContactMethods.Add(new ContactMethodDto { Type = "", Value = "" });
    }

    private void RemoveContact(ContactMethodDto contact)
    {
        model.ContactMethods.Remove(contact);
    }

    // Languages
    private void AddLanguage()
    {
        model.Languages.Add(new LanguageDto { Name = "", Level = "" });
    }

    private void RemoveLanguage(LanguageDto lang)
    {
        model.Languages.Remove(lang);
    }

    private void AddFramework()
    {
        var trimmed = newFramework?.Trim();

        if (!string.IsNullOrWhiteSpace(trimmed))
        {
            // Case-insensitive check: prevents duplicates like "React" and "react"
            bool alreadyExists = model.Frameworks
                .Any(f => string.Equals(f, trimmed, StringComparison.OrdinalIgnoreCase));

            if (!alreadyExists)
            {
                model.Frameworks.Add(trimmed);
            }
        }

        // Clear the input even if it was a duplicate to reset the UI
        newFramework = "";
    }

    private void OnFrameworkKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddFramework();
            StateHasChanged();
        }
    }

    private void RemoveFramework(string fw)
    {
        model.Frameworks.Remove(fw);
    }

    // Work Experience
    private void AddWorkExperience()
    {
        model.WorkExperiences.Add(new WorkExperienceFormModel
        {
            StartDate = DateOnly.FromDateTime(DateTime.Now),
            EndDate = null
        });
    }

    private void RemoveWorkExperience(WorkExperienceFormModel we)
    {
        model.WorkExperiences.Remove(we);
    }

    private async Task Save()
    {
        isSaving = true;
        ErrorMessage = null;

        try
        {
            var skillsDto = new SkillsMatrixDto(
                model.Languages,
                model.Frameworks
            );

            var workExperiencesDto = model.WorkExperiences.Select(we => new WorkExperienceDto(
                we.Id,
                we.CompanyName,
                we.Position,
                we.StartDate,
                we.EndDate,
                we.Description,
                we.Technologies
            )).ToList();

            HttpResponseMessage response;
            if (IsEdit && model.Id.HasValue)
            {
                var updateRequest = new UpdateResumeRequest(
                    model.Id.Value,
                    model.FullName,
                    model.Title,
                    model.Location,
                    model.ExpectedSalary,
                    model.ContactMethods,
                    skillsDto,
                    model.IsVisible,
                    model.AboutMe,
                    workExperiencesDto
                );
                response = await ResumeApi.UpdateAsync(model.Id.Value, updateRequest);
            }
            else
            {
                var createRequest = new CreateResumeRequest(
                    model.FullName,
                    model.Title,
                    model.Location,
                    model.ExpectedSalary,
                    model.ContactMethods,
                    skillsDto,
                    model.IsVisible,
                    model.AboutMe,
                    workExperiencesDto
                );
                response = await ResumeApi.CreateAsync(createRequest);
            }

            if (response.IsSuccessStatusCode)
            {
                await OnSuccess.InvokeAsync();
                await CloseModal();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Error: {error}";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CloseModal()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "#resumeModal");
    }

    public class ResumeFormModel
    {
        public Guid? Id { get; set; }
        public string FullName { get; set; } = "";
        public string Title { get; set; } = "";
        public string Location { get; set; } = "";
        public decimal? ExpectedSalary { get; set; } = 0;
        public string AboutMe { get; set; } = "";
        public bool IsVisible { get; set; } = true;

        public List<ContactMethodDto> ContactMethods { get; set; } = new();
        public List<LanguageDto> Languages { get; set; } = new();
        public List<string> Frameworks { get; set; } = new();
        public List<WorkExperienceFormModel> WorkExperiences { get; set; } = new();
    }

    public class WorkExperienceFormModel
    {
        public Guid? Id { get; set; }
        public string CompanyName { get; set; } = "";
        public string Position { get; set; } = "";
        public DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Now);
        public DateOnly? EndDate { get; set; }
        public string Description { get; set; } = "";
        public List<string> Technologies { get; set; } = new();

        // New property to track the text input for THIS specific work experience
        public string NewTech { get; set; } = "";

        public DateTime? StartMonthYear
        {
            get => new DateTime(StartDate.Year, StartDate.Month, 1);
            set => StartDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Now);
        }

        public DateTime? EndMonthYear
        {
            get => EndDate.HasValue ? new DateTime(EndDate.Value.Year, EndDate.Value.Month, 1) : null;
            set => EndDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        }
    }
}