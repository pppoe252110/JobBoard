@page "/profile"
@using System.Security.Claims
@using JobBoard.Web.Components.Pages.Forms
@using JobBoard.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthApiClient AuthApi
@inject NavigationManager NavManager
@inject VacancyApiClient VacancyApi
@inject ResumeApiClient ResumeApi
@inject IJSRuntime JsRuntime

@attribute [Authorize]

@rendermode InteractiveServer

<PageTitle>My Profile</PageTitle>

<div class="container py-5">
    <h1 class="display-5 fw-bold mb-4 text-center">My Profile</h1>

    <ul class="nav nav-pills nav-fill border-0 gap-3 mb-4" id="profileTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active hover-lift rounded-4 px-4 py-3 fw-semibold border-0 shadow-sm" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab">
                <i class="bi bi-person-circle me-2"></i>Account Info
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link hover-lift rounded-4 px-4 py-3 fw-semibold border-0 shadow-sm" id="vacancies-tab" data-bs-toggle="tab" data-bs-target="#vacancies" type="button" role="tab">
                <i class="bi bi-briefcase me-2"></i>My Vacancies
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link hover-lift rounded-4 px-4 py-3 fw-semibold border-0 shadow-sm" id="resumes-tab" data-bs-toggle="tab" data-bs-target="#resumes" type="button" role="tab">
                <i class="bi bi-file-text me-2"></i>My Resumes
            </button>
        </li>
    </ul>

    <div class="tab-content" id="profileTabContent">
        <!-- Account Info Tab -->
        <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="info-tab">
            @if (profile == null)
            {
                <div class="d-flex justify-content-center align-items-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading profile...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card border-0 shadow rounded-4 h-100">
                            <div class="card-body p-4">
                                <h4 class="fw-bold mb-4">
                                    <i class="bi bi-pencil-square me-2"></i>Edit Profile
                                </h4>

                                <div class="mb-4">
                                    <label for="nicknameInput" class="form-label fw-semibold">Nickname</label>
                                    <div class="input-group">
                                        <input id="nicknameInput" name="nickname" type="text" class="form-control rounded-3" @bind="editNickname" autocomplete="username" />
                                        <button class="btn btn-primary rounded-3" @onclick="UpdateNickname" disabled="@isUpdating">
                                            @(isUpdating ? "Saving..." : "Save")
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(nicknameError))
                                    {
                                        <div class="text-danger mt-2 small">@nicknameError</div>
                                    }
                                </div>

                                <hr />

                                <h5 class="fw-bold mb-3">Change Password</h5>
                                <div class="mb-3">
                                    <label for="currentPasswordInput" class="form-label">Current Password</label>
                                    <input id="currentPasswordInput" name="currentPassword" type="password" class="form-control rounded-3" @bind="currentPassword" autocomplete="current-password" />
                                </div>

                                <div class="mb-3">
                                    <label for="newPasswordInput" class="form-label">New Password</label>
                                    <input id="newPasswordInput" name="newPassword" type="password" class="form-control rounded-3" @bind="newPassword" autocomplete="new-password" />
                                </div>

                                <div class="mb-4">
                                    <label for="confirmPasswordInput" class="form-label">Confirm New Password</label>
                                    <input id="confirmPasswordInput" name="confirmPassword" type="password" class="form-control rounded-3" @bind="confirmPassword" autocomplete="new-password" />
                                </div>

                                <div class="d-flex gap-3 align-items-center">
                                    <button class="btn btn-outline-primary rounded-pill px-4" @onclick="ChangePassword" disabled="@isChangingPassword">
                                        @(isChangingPassword ? "Changing..." : "Change Password")
                                    </button>

                                    <form id="logoutForm" name="logoutForm" action="/auth/logout-callback" method="post" class="d-inline">
                                        <AntiforgeryToken />
                                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                                            <i class="bi bi-box-arrow-right me-1"></i> Log Out
                                        </button>
                                    </form>
                                </div>

                                @if (!string.IsNullOrEmpty(passwordMessage))
                                {
                                    <div class="alert alert-info mt-4 rounded-3">@passwordMessage</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden">
                            <div class="card-body p-4 p-md-5 text-center">
                                <div class="d-flex justify-content-center mb-4">
                                    <div class="bg-body-secondary" style="width: 100px; height: 100px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-person-circle text-body-secondary" style="font-size: 3rem"></i>
                                    </div>
                                </div>

                                <h3 class="fw-bold mb-1 text-break">@profile.Nickname</h3>
            
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                                    <i class="bi bi-envelope-fill text-primary small"></i>
                                    <p class="text-primary fw-medium mb-0 text-break">@profile.Email</p>
                                </div>

                                <hr class="my-4 opacity-50">

                                <div class="d-flex align-items-center justify-content-center gap-2 text-secondary small text-uppercase">
                                    <i class="bi bi-calendar-check-fill"></i>
                                    <span>Joined @profile.CreatedAt.ToString("MMMM yyyy")</span>
                                </div>

                                <div class="d-flex justify-content-center gap-3 mt-4">
                                    <a href="#" class="btn btn-sm btn-outline-primary rounded-pill px-4">Message</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- My Vacancies Tab -->
        <div class="tab-pane fade" id="vacancies" role="tabpanel" aria-labelledby="vacancies-tab">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">
                    <i class="bi bi-briefcase-fill me-2"></i>Your Vacancies
                </h3>
                <button class="btn btn-primary rounded-pill px-4" @onclick="ShowCreateVacancyModal">
                    <i class="bi bi-plus-lg me-2"></i>Create New Vacancy
                </button>
            </div>

            @if (userVacancies == null)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (!userVacancies.Any())
            {
                <div class="card border-0 shadow rounded-4 bg-light text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-briefcase fs-1 text-secondary"></i>
                        <h5 class="mt-3">No vacancies yet</h5>
                        <p class="text-secondary">Click the button above to create your first vacancy.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var vacancy in userVacancies)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow rounded-4 overflow-hidden">
                                <div class="card-body p-4 d-flex flex-column">
                                    <h5 class="card-title fw-bold mb-2">@vacancy.Title</h5>
                                    <p class="card-text text-muted mb-3">@Truncate(vacancy.DescriptionMarkdown, 100)</p>
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="badge rounded-pill text-bg-secondary">@FormatSalary(vacancy.SalaryFrom, vacancy.SalaryTo)</span>
                                        <span class="badge rounded-pill text-bg-info">@vacancy.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    </div>
                                    <div class="mt-auto d-flex gap-2">
                                        <a href="/vacancy/@vacancy.Id/manage" class="btn btn-sm btn-info rounded-pill flex-fill text-white">
                                            <i class="bi bi-people me-1"></i>Candidates
                                        </a>
                                        <button class="btn btn-sm btn-outline-primary rounded-pill flex-fill" @onclick="() => EditVacancy(vacancy)">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill flex-fill" @onclick="() => DeleteVacancy(vacancy.Id)">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- My Resumes Tab -->
        <div class="tab-pane fade" id="resumes" role="tabpanel" aria-labelledby="resumes-tab">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">
                    <i class="bi bi-file-text-fill me-2"></i>Your Resumes
                </h3>
                <button class="btn btn-primary rounded-pill px-4" @onclick="ShowCreateResumeModal">
                    <i class="bi bi-plus-lg me-2"></i>Create New Resume
                </button>
            </div>

            @if (userResumes == null)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (!userResumes.Any())
            {
                <div class="card border-0 shadow rounded-4 bg-light text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-file-text fs-1 text-secondary"></i>
                        <h5 class="mt-3">No resumes yet</h5>
                        <p class="text-secondary">Click the button above to create your first resume.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var resume in userResumes)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow rounded-4 overflow-hidden">
                                <div class="card-body p-4 d-flex flex-column">
                                    <h5 class="card-title fw-bold mb-2">@resume.Title</h5>
                                    <p class="card-text text-muted mb-3">@Truncate(resume.AboutMe, 100)</p>
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        @foreach (var skill in (resume.Skills.Languages?.Select(l => l.Name) ?? Enumerable.Empty<string>())
                                                                                                                        .Concat(resume.Skills.HardSkills ?? Enumerable.Empty<string>()))
                                        {
                                            <span class="badge rounded-pill text-bg-secondary">@skill</span>
                                        }
                                    </div>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span class="badge @(resume.IsVisible ? "text-bg-success" : "text-bg-secondary") rounded-pill">
                                            @(resume.IsVisible ? "Public" : "Hidden")
                                        </span>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill" @onclick="() => EditResume(resume)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill" @onclick="() => DeleteResume(resume.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<VacancyForm ExistingVacancy="@editingVacancy" OnSuccess="RefreshVacancies" />
<ResumeForm ExistingResume="@editingResume" OnSuccess="RefreshResumes" />


@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private ProfileResponse? profile;
    private string editNickname = "";
    private string nicknameError = "";
    private bool isUpdating;

    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private bool isChangingPassword;
    private string? passwordMessage;

    private List<VacancyResponse>? userVacancies;
    private List<ResumeResponse>? userResumes;

    private VacancyResponse? editingVacancy;
    private ResumeResponse? editingResume;

    protected override async Task OnInitializedAsync()
    {
        profile = await AuthApi.GetProfileAsync();
        if (profile != null) editNickname = profile.Nickname;

        userVacancies = await VacancyApi.GetUserVacanciesAsync();
        userResumes = await ResumeApi.GetUserResumesAsync();
    }

    private async Task UpdateNickname()
    {
        if (string.IsNullOrWhiteSpace(editNickname))
        {
            nicknameError = "Nickname cannot be empty.";
            return;
        }

        isUpdating = true;
        nicknameError = "";
        var success = await AuthApi.UpdateProfileAsync(editNickname);
        if (success)
        {
            profile = new ProfileResponse(profile!.Id, editNickname, profile.Email, profile.CreatedAt);
        }
        else
        {
            nicknameError = "Nickname update failed. It might be already taken.";
        }
        isUpdating = false;
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            passwordMessage = "Please fill in all fields.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordMessage = "New passwords do not match.";
            return;
        }

        isChangingPassword = true;
        passwordMessage = "";
        var success = await AuthApi.ChangePasswordAsync(currentPassword, newPassword);
        if (success)
        {
            passwordMessage = "Password changed successfully.";
            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
        }
        else
        {
            passwordMessage = "Failed to change password. Check your current password.";
        }
        isChangingPassword = false;
    }

    private async Task DeleteVacancy(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this vacancy?"))
        {
            var response = await VacancyApi.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                userVacancies = await VacancyApi.GetUserVacanciesAsync();
                StateHasChanged();
            }
        }
    }

    private async Task DeleteResume(Guid id)
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this resume?"))
        {
            var response = await ResumeApi.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                userResumes = await ResumeApi.GetUserResumesAsync();
                StateHasChanged();
            }
        }
    }

    private void ShowCreateVacancyModal()
    {
        editingVacancy = null;
        JsRuntime.InvokeVoidAsync("showModal", "#vacancyModal");
    }

    private void EditVacancy(VacancyResponse vacancy)
    {
        editingVacancy = vacancy;
        JsRuntime.InvokeVoidAsync("showModal", "#vacancyModal");
    }

    private void ShowCreateResumeModal()
    {
        editingResume = null;
        JsRuntime.InvokeVoidAsync("showModal", "#resumeModal");
    }

    private void EditResume(ResumeResponse resume)
    {
        editingResume = resume;
        JsRuntime.InvokeVoidAsync("showModal", "#resumeModal");
    }

    private async Task RefreshVacancies()
    {
        userVacancies = await VacancyApi.GetUserVacanciesAsync();
        StateHasChanged();
    }

    private async Task RefreshResumes()
    {
        userResumes = await ResumeApi.GetUserResumesAsync();
        StateHasChanged();
    }

    private string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "...";

    private string FormatSalary(decimal? from, decimal? to) =>
        (from, to) switch
        {
            (null, null) => "Salary not specified",
            (null, decimal t) => $"Up to {t:N0}",
            (decimal f, null) => $"From {f:N0}",
            (decimal f, decimal t) => $"{f:N0} - {t:N0}"
        };
}